	  "group/notify",
		"hyprland/workspaces#rw",
		],
	
	"modules-center": [
			"clock",
      "clock#date",

		],
	
	"modules-right": [
    "custom/keyboard",
		"tray",
		"custom/separator#dot-line",
		"group/laptop",
		"custom/separator#dot-line",
		"group/mobo_drawer",
		"custom/separator#line",  
		"group/audio",
