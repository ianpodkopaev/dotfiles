# /* ---- 💫 https://github.com/JaKooLit 💫 ---- */  #
# wallust template - colors-fish

# Terminal ANSI colors (complement kitty)
set -g fish_term24bit 1

# Syntax highlighting
set -g fish_color_normal #F0F0F0
set -g fish_color_command #9D9C9D
set -g fish_color_param #9F9E9F
set -g fish_color_error #3E3E3E
set -g fish_color_end #828181
set -g fish_color_operator #828181
set -g fish_color_quote #858585
set -g fish_color_redirection #9D9C9D
set -g fish_color_escape #828181
set -g fish_color_autosuggestion #9E9D9E
set -g fish_color_selection --background=#464546
set -g fish_color_search_match --background=#464546
set -g fish_color_cancel #3E3E3E
set -g fish_color_keyword #3E3E3E

# Prompt colors
set -g fish_color_cwd #828181
set -g fish_color_user #9D9C9D
set -g fish_color_host #9F9E9F
set -g fish_color_host_remote #9D9C9D

# Pager (tab completion)
set -g fish_pager_color_progress #3E3E3E --bold
set -g fish_pager_color_prefix #9D9C9D --bold
set -g fish_pager_color_completion #F0F0F0
set -g fish_pager_color_description #9E9D9E
set -g fish_pager_color_selected_background --background=#464546
set -g fish_pager_color_selected_prefix #9D9C9D --bold
set -g fish_pager_color_selected_completion #F0F0F0
